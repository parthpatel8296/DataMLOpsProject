# User Request: Explicitly ignore documentation
docs/

# Python defaults
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.env
.ipynb_checkpoints/

# DVC defaults (do not ignore .dvc files, but ignore cache)
.dvc/cache
.dvc/tmp

# Editor defaults
.vscode/
.idea/

# Large Data (Explicitly ignore all data, DVC will handle exceptions via its own .gitignore)
data/
!data/**/*.dvc
!data/processed/features/*.sql
# DVC creates .gitignore inside data/ to whitelist .dvc files, so we generally shouldn't ignore data/ completely 
# unless we rely on the sub-gitignores.
# To be safe and follow DVC best practices, we usually do NOT ignore data/ in root, 
# but rely on data/.gitignore generated by DVC.
# However, to keep it clean as requested, if we ignore data/ here, we must force add tracked files.
# BETTER APPROACH: Let DVC handle data folders. 
# Reverting the global data/ ignore to avoid conflicts with DVC.

# Ignore logs
*.log

# MLflow runs
mlruns/

metrics/

# Data and Databases
*.parquet
*.db
feast_repo/data/registry.db
feast_repo/data/online_store.db
